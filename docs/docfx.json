{
  "metadata": [
    {
      "src": [
        {
          "src": "../UltraLiteDB",
          "files": ["UltraLiteDB.csproj"]
        }
      ],
      "dest": "api",
      "properties": {
        "TargetFramework": "netstandard2.1"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": ["api/**.yml", "api/index.md"]
      },
      {
        "files": ["toc.yml", "index.md"]
      },
      {
        "files": ["guides/**.md", "guides/toc.yml"]
      }
    ],
    "dest": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata" :
    {
      "_appTitle" : "UltraLiteDB",
      "_enableSearch": true,
      "_disableContribution": true
    }
  }
}